APP_ENV=dev
APP_SECRET=change_me_to_32_random_chars_now

DATABASE_URL="mysql://vehicle_user:vehicle_password@mysql:3306/vehicle_api?serverVersion=8.4&charset=utf8mb4"

MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=vehicle_api
MYSQL_USER=vehicle_user
MYSQL_PASSWORD=vehicle_password

NGINX_PORT=8080
MYSQL_PORT=3306
PMA_PORT=8081

CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
