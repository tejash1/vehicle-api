# Copy this file to .env and fill in your values
# .env is committed; .env.local overrides it and is git-ignored

APP_ENV=dev
APP_SECRET=change_me_to_32_random_chars_now

# The host "mysql" resolves inside Docker to the mysql container
DATABASE_URL="mysql://vehicle_user:vehicle_password@mysql:3306/vehicle_api?serverVersion=8.4&charset=utf8mb4"

# These values are read by the mysql service in docker-compose.yml
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=vehicle_api
MYSQL_USER=vehicle_user
MYSQL_PASSWORD=vehicle_password

# Exposed ports on your host machine — change if there are conflicts
NGINX_PORT=8080
MYSQL_PORT=3306
PMA_PORT=8081

CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
